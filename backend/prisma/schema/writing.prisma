// ── ENUMS ────────────────────────────────────────────────────────────────

enum WritingType {
  SENTENCE
  PARAGRAPH
  ESSAY
}

enum SubmissionStatus {
  PENDING
  ANALYZED
  ERROR
}

// ── EMBEDDED TYPES (Вложенные объекты для анализа) ───────────────────────

// 1. Конкретная ошибка в тексте
type WritingError {
  message      String
  context      String
  offset       Int
  length       Int
  replacements String[]
}

// 2. Полный объект анализа AI
type WritingAnalysis {
  overallScore   Float
  grammarScore   Float
  taskScore      Float
  coherenceScore Float
  wordCount      Int
  errorCount     Int
  feedback      String? // Общий совет от AI (например, "Try using more complex conjunctions")
  detectedTone  String? // Например: "Formal", "Academic" - важно для TOEFL
  errors         WritingError[] // Массив вложенных типов ошибок
}

// ── MODELS ───────────────────────────────────────────────────────────────

// Темы (Промпты) для заданий по письму
model WritingPrompt {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  
  prompt       String
  level        Level         // Твой существующий enum (A1, B2...)
  type         WritingType   @default(PARAGRAPH)
  
  minWords     Int           @default(50)
  maxWords     Int           @default(200)
  
  topic        String        @default("")
  instructions String        @default("")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Связь: один промпт может иметь много попыток решения
  submissions  WritingSubmission[]

  @@index([level])
}

// Решения пользователей и их анализ
model WritingSubmission {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  
  // Связь с пользователем
  userId      String            @db.ObjectId
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Связь с промптом
  promptId    String            @db.ObjectId
  prompt      WritingPrompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)

  text        String
  
  // Вложенный объект анализа (может быть null, пока статус PENDING)
  analysis    WritingAnalysis?
  
  status      SubmissionStatus  @default(PENDING)
  submittedAt DateTime          @default(now())

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, promptId])
}