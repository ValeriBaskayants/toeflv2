model TtsCache {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  contentHash String   @unique

  textLength  Int
  voiceId     String
  modelId     String

  audioBase64 String

  hitCount    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}