
enum PartOfSpeech {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PHRASE
}

enum WordLearningStatus {
  NEW
  LEARNING
  REVIEW
  MASTERED
}

type WordForms {
  base              String?
  past              String?
  pastParticiple    String?
  thirdPerson       String?
  presentParticiple String?
}

model Vocabulary {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  
  word            String       @unique
  level           Level      
  type            PartOfSpeech @default(NOUN)
  
  pronunciation   String       @default("")
  definition      String
  definitionRu    String       @default("")
  
  examples        String[]
  synonyms        String[]
  antonyms        String[]
  
  imageUrl        String?
  
  forms           WordForms?   
  isIrregularVerb Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  userProgress    UserVocabularyProgress[]

  @@index([level, type])
}

model UserVocabularyProgress {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId

  userId          String             @db.ObjectId
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  wordId          String             @db.ObjectId
  vocabulary      Vocabulary         @relation(fields: [wordId], references: [id], onDelete: Cascade)

  easinessFactor  Float              @default(2.5) 
  interval        Int                @default(1)
  repetitions     Int                @default(0)
  nextReviewDate  DateTime           @default(now())
  
  status          WordLearningStatus @default(NEW)
  lastReviewedAt  DateTime?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId, wordId]) 
  
  @@index([userId, nextReviewDate])
}