// backend/prisma/schema/writing.prisma  — UPDATED
// ════════════════════════════════════════════════════════════════════════════
// CHANGE: added `vocabularyScore Float` to WritingAnalysis embedded type
// to match what writing.processor.ts now saves.
// Without this field Prisma silently drops it (MongoDB BSON → schema mismatch).

enum WritingType {
  SENTENCE
  PARAGRAPH
  ESSAY
}

enum SubmissionStatus {
  PENDING
  ANALYZED
  ERROR
}

type WritingError {
  message      String
  context      String
  offset       Int
  length       Int
  replacements String[]
}

// ← vocabularyScore added: Guiraud-Index-based lexical diversity score (0-100)
type WritingAnalysis {
  overallScore    Float
  grammarScore    Float
  taskScore       Float
  coherenceScore  Float
  vocabularyScore Float   // NEW — was missing, caused `as any` cast workaround
  wordCount       Int
  errorCount      Int
  feedback        String?
  detectedTone    String?
  errors          WritingError[]
}

model WritingPrompt {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  
  prompt       String
  level        Level
  type         WritingType   @default(PARAGRAPH)
  
  minWords     Int           @default(50)
  maxWords     Int           @default(200)
  
  topic        String        @default("")
  instructions String        @default("")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  submissions  WritingSubmission[]

  @@index([level])
}

model WritingSubmission {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  
  userId      String            @db.ObjectId
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  promptId    String            @db.ObjectId
  prompt      WritingPrompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)

  text        String
  analysis    WritingAnalysis?
  status      SubmissionStatus  @default(PENDING)
  submittedAt DateTime          @default(now())

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, promptId])
  @@index([userId, status])   // useful for "show my pending submissions"
}
