enum MistakeSource {
  QUIZ
  WRITING
  READING
  LISTENING
}

enum ErrorCategory {
  GRAMMAR      
  VOCABULARY  
  SPELLING     
  LOGIC     
}

enum MasteryStatus {
  LEARNING     
  REVIEWING   
  MASTERED   
}

model UserMistake {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetId    String  
  source      MistakeSource
  grammarRuleId String? @db.ObjectId
  topic       String 
  category    ErrorCategory 
  level       Level    @default(A1) 

  status      MasteryStatus @default(LEARNING)
  nextReview  DateTime?     
  easeFactor  Float         @default(2.5)

  wrongCount  Int      @default(1)
  correctCount Int     @default(0) 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attempts    MistakeAttempt[]

  @@unique([userId, targetId])
  
  @@index([userId, nextReview])
  @@index([userId, topic])
}

model MistakeAttempt {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  
  userMistakeId   String   @db.ObjectId
  userMistake     UserMistake @relation(fields: [userMistakeId], references: [id], onDelete: Cascade)

  userAnswer      String 
  correctAnswer   String  
  isCorrect       Boolean  @default(false) 

  createdAt       DateTime @default(now()) 
}

