model Bookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetId  String   
  type      BookmarkType

  createdAt DateTime @default(now())

  @@unique([userId, targetId, type])
  @@index([userId])
}

enum BookmarkType {
  GRAMMAR_RULE
  VOCABULARY
  READING
  WRITING_PROMPT
}