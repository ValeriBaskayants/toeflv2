enum PlacementStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  REMIND_LATER
}

model PlacementTest {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  status PlacementStatus @default(PENDING)

  theta         Json @default("{\"grammar\":0,\"vocabulary\":0,\"reading\":0,\"listening\":0}")

  standardError Json @default("{\"grammar\":2,\"vocabulary\":2,\"reading\":2,\"listening\":2}")

  questions Json @default("[]")

  answers   Json @default("[]")

  remindAfter DateTime?

  startedAt   DateTime?
  lastActivityAt DateTime?

  /// Time of first completion (never updated on retakes)
  completedAt     DateTime?
  /// Time of last completion (updated on every retake)
  lastCompletedAt DateTime?

  detectedLevel   Level?
  confidenceScore Int?

  attemptCount Int @default(0)

  /// Time when test was completed (first/current attempt)
  completedAt DateTime?
  /// Last time test was completed (updated on retakes)
  lastCompletedAt DateTime?

  testDurationSeconds Int?
  averageAnswerTimeSeconds Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId, status])
}